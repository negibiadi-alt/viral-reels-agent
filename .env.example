# === Apify ===
APIFY_TOKEN=

# === Telegram ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_APPROVER_CHAT_ID=

# === Instagram Graph API (Business/Creator) ===
IG_USER_ID=
IG_ACCESS_TOKEN=

# === YouTube Data API v3 ===
YT_CLIENT_SECRETS_FILE=./secrets/yt_client_secret.json
YT_TOKEN_FILE=./secrets/yt_token.json

# === Database ===
DATABASE_URL=sqlite:///./storage/app.db
# For prod: postgresql+psycopg://user:pass@postgres:5432/viral_reels

# === Runtime ===
TIMEZONE=Europe/Istanbul
DAILY_CANDIDATES=5
MAX_CANDIDATE_AGE_DAYS=7
DRY_RUN=true

# === Viral thresholds ===
MIN_VIEWS=50000
MIN_ENGAGEMENT_RATE=0.03
MIN_VIEWS_PER_HOUR=1000

# === Storage ===
DOWNLOAD_DIR=./storage/downloaded
PROCESSED_DIR=./storage/processed

# === YouTube Data API v3 (sadece API key, OAuth yok) ===
# console.cloud.google.com → YouTube Data API v3 → Credentials → API Key
YOUTUBE_API_KEY=

# === TikTok — Omkar Cloud (ücretsiz 5000 istek/ay) ===
# https://omkar.cloud → kayıt ol → API key al
OMKAR_API_KEY=

# === Claude (optional — topic expansion agent) ===
ANTHROPIC_API_KEY=
